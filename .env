
# DISCORD

DISCORD_TOKEN=Do

# Pode colocar mais de 3 IDs separados por vírgula.
OWNER_IDS=936533144218239016,1511490598035652669,243449384048656385,222222222222222222,333333333333333333


# LLM_PROVIDER opções:
# openrouter | groq | ollama_cloud | ollama_local | custom

LLM_PROVIDER=ollama_cloud

# OPENROUTER
OPENROUTER_API_KEY=coloque_sua_openrouter_key_aqui
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=REPLICANT

# GROQ
GROQ_API_KEY=coloque_sua_groq_key_aqui
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OLLAMA CLOUD 
# O daemon local do Ollama roteia modelos ":cloud" para a nuvem automaticamente.
# OLLAMA_API_KEY = sua chave da Ollama Cloud
# OLLAMA_CLOUD_MODEL = modelo COM sufixo :cloud (ex: gemma4:31b-cloud)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=gemma4:31b-cloud
OLLAMA_CLOUD_BASE_URL=http://127.0.0.1:11434

# OLLAMA LOCAL (sem cloud)
OLLAMA_LOCAL_MODEL=llama3.2
OLLAMA_LOCAL_BASE_URL=http://127.0.0.1:11434
OLLAMA_LOCAL_API_KEY=


# OPÇÃO 1 — Cloud (recomendado, sem instalar nada):
#   VISION_MODEL=llama3.2-vision:11b-cloud
#
# OPÇÃO 2 — Local (precisa baixar: ollama pull llava:13b):
#   VISION_MODEL=llava:13b
#
# OPÇÃO 3 — Local leve (ollama pull minicpm-v, ~4GB):
#   VISION_MODEL=minicpm-v
#
# Deixe vazio para desativar análise de imagem.
# gemma4:31b-cloud já é multimodal — analisa imagens sem precisar de modelo separado.
VISION_MODEL=gemma4:31b-cloud

# CUSTOM / OPENAI-COMPATIBLE GENÉRICO
CUSTOM_LLM_BASE_URL=https://api.exemplo.com/v1
CUSTOM_LLM_API_KEY=coloque_sua_api_key_aqui
CUSTOM_LLM_MODEL=llama3.2

# Configuração comum da geração
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.35
LLM_MAX_TOKENS=700

# Fallback manual (sobrescreve o provider acima se preenchido):
# Aponte para o daemon local — o sufixo :cloud no modelo faz o roteamento.
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=
LLM_MODEL=gemma4:31b-cloud

# PESQUISA SILENCIOSA
# A IA pode pedir pesquisa, mas o código só pesquisa se isso estiver ligado.
SEARCH_ENABLED=true
SEARCH_PROVIDER=duckduckgo
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT=12
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# BOT

BOT_PREFIX=r!
DATABASE_PATH=data/bot.sqlite3
EMBED_COLOR=5865F2
MAX_HISTORY_MESSAGES=20
APP_NAME=REPLICANT
APP_VERSION=0.5-clean
LOG_LEVEL=INFO
